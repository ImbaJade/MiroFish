# =========================================
# MiroFish environment template
# =========================================

# Flask
FLASK_DEBUG=true
SECRET_KEY=mirofish-secret-key

# =========================================
# Core LLM (OpenAI-compatible)
# =========================================
# Online example:
# LLM_API_KEY=your_api_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# Offline/local vLLM or Ollama example:
LLM_API_KEY=offline-local-key
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct

# =========================================
# Memory backend: zep | local | mem0
# =========================================
OFFLINE_MODE=true
MEMORY_BACKEND=local

# Only required when MEMORY_BACKEND=zep
ZEP_API_KEY=

# =========================================
# Optional model services (reserved for extension)
# =========================================
# OCR
OCR_API_BASE_URL=
OCR_API_KEY=
OCR_PROVIDER=local
OCR_TIMEOUT_SECONDS=60

# Embedding
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=
EMBEDDING_DIM=

# Rerank
RERANK_API_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL_NAME=
RERANK_TOP_K=20

# Report Agent
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5

# OASIS simulation
OASIS_DEFAULT_MAX_ROUNDS=10
